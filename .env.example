# Resend API Key - get yours at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Email address where form submissions will be sent (business owner's email)
RECIPIENT_EMAIL=owner@yourbusiness.com

# The "from" email (must be a verified domain in Resend, or use onboarding@resend.dev for testing)
FROM_EMAIL=noreply@yourdomain.com

# Company name shown throughout the site
NEXT_PUBLIC_COMPANY_NAME=YOUR COMPANY
